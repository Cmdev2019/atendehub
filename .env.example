# ─────────────────────────────────────────────────────────────────────────────
# AtendeHub — Variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Aplicação ─────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3001
APP_URL=http://localhost:3001

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=atendehub
POSTGRES_PASSWORD=atendehub_secret
POSTGRES_DB=atendehub
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# URL completa usada pelo Prisma
DATABASE_URL=postgresql://atendehub:atendehub_secret@localhost:5432/atendehub?schema=atendehub

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379

# ── MinIO (S3) ────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=atendehub_minio
MINIO_ROOT_PASSWORD=minio_secret_123
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=atendehub-media
MINIO_REGION=us-east-1

# ── Evolution API ─────────────────────────────────────────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=evolution_api_key_dev
EVOLUTION_SERVER_URL=http://localhost:8080
# URL que a Evolution vai chamar ao receber mensagem (deve ser acessível pelo container)
EVOLUTION_WEBHOOK_URL=http://host.docker.internal:3001/api/v1/webhooks/evolution

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_por_um_segredo_forte_de_64_bytes_minimo
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=troque_por_outro_segredo_forte_diferente_do_acesso
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Throttle (rate limit) ──────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
