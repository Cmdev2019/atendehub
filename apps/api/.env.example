# ─────────────────────────────────────────────────────────────────────────────
# AtendeHub — Variáveis de ambiente (EXEMPLO)
# Copie este arquivo para .env e preencha os valores reais
# cp .env.example .env
#
# ⚠️  NUNCA comita o arquivo .env com valores reais!
# ─────────────────────────────────────────────────────────────────────────────

# ── Aplicação ─────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3001
APP_URL=http://localhost:3001

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
POSTGRES_USER=atendehub
POSTGRES_PASSWORD=<gerar_senha_aleatoria>

POSTGRES_DB=atendehub
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# URL completa usada pelo Prisma
DATABASE_URL=postgresql://<user>:<password>@localhost:5432/atendehub?schema=atendehub

# ── Redis ─────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<gerar_senha_aleatoria_ou_deixar_vazio>

REDIS_URL=redis://:password@localhost:6379

# ── MinIO (S3) ────────────────────────────────────────────────────────────────
# IMPORTANTE: Configure valores reais em produção/staging!
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MINIO_ROOT_USER=<seu_usuario_aleatorio>
MINIO_ROOT_PASSWORD=<sua_senha_gerada_acima>
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=atendehub-media
MINIO_REGION=us-east-1

# ── Evolution API (WhatsApp) ──────────────────────────────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=<obter_da_evolution_api>
EVOLUTION_SERVER_URL=http://localhost:8080
# URL que a Evolution vai chamar ao receber mensagem (deve ser acessível pelo container)
EVOLUTION_WEBHOOK_URL=http://host.docker.internal:3001/api/v1/webhooks/evolution

# ── JWT (Autenticação) ────────────────────────────────────────────────────────
# CRÍTICO: Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Nunca use valores padrão em produção!
JWT_SECRET=<gerar_com_comando_acima>

JWT_EXPIRES_IN=15m

# CRÍTICO: Use um valor DIFERENTE de JWT_SECRET
JWT_REFRESH_SECRET=<gerar_com_comando_acima_diferente>

JWT_REFRESH_EXPIRES_IN=7d

# ── CORS (Origem do Frontend) ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Throttle (Rate Limiting) ──────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─────────────────────────────────────────────────────────────────────────────
# INSTRUÇÕES DE SETUP
# ─────────────────────────────────────────────────────────────────────────────
#
# 1. Copie este arquivo para .env
#    $ cp .env.example .env
#
# 2. Gere secrets fortes:
#    $ node -e "console.log('JWT_SECRET:', require('crypto').randomBytes(64).toString('hex'))"
#    $ node -e "console.log('JWT_REFRESH_SECRET:', require('crypto').randomBytes(64).toString('hex'))"
#
# 3. Preenchha todos os valores com <...> no .env
#
# 4. Configure seu banco de dados:
#    $ npm run db:migrate
#    $ npm run db:seed
#
# 5. Inicie o servidor:
#    $ npm run start:dev
#
# ─────────────────────────────────────────────────────────────────────────────
# ⚠️  SECURITY WARNING
# ─────────────────────────────────────────────────────────────────────────────
# - NUNCA comita .env com valores reais
# - NUNCA compartilhe valores de secrets
# - MUDE as senhas padrão em produção
# - Use variáveis de ambiente em deployment
# - Rotate secrets regularmente
# ─────────────────────────────────────────────────────────────────────────────
